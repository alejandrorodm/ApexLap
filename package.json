{
  "name": "apexlap",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo-google-fonts/orbitron": "^0.4.2",
    "@expo/metro-runtime": "~56.0.13",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "expo": "~56.0.8",
    "expo-clipboard": "~56.0.3",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-notifications": "~56.0.15",
    "expo-sharing": "~56.0.16",
    "expo-status-bar": "~56.0.4",
    "firebase": "^12.14.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-view-shot": "5.1.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "patch-package": "^8.0.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "zip:mod": "cd tools && rm -f ../dist/ApexLap-mod.zip && zip -rq ../dist/ApexLap-mod.zip ApexLap -x '*/.DS_Store'",
    "copy:apk": "node -e \"const fs=require('fs');fs.existsSync('release/ApexLap.apk')?(fs.mkdirSync('dist',{recursive:true}),fs.copyFileSync('release/ApexLap.apk','dist/ApexLap.apk'),console.log('APK copiado a dist/')):console.log('Sin release/ApexLap.apk: se omite (el enlace de Perfil dará 404 hasta que lo subas).')\"",
    "deploy:web": "expo export --platform web && npm run zip:mod && npm run copy:apk && firebase deploy --only hosting,firestore:rules",
    "build:apk": "eas build -p android --profile preview"
  },
  "private": true
}
