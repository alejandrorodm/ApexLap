{
  "name": "apexlap",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/metro-runtime": "~56.0.13",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "expo": "~56.0.8",
    "expo-clipboard": "~56.0.3",
    "expo-device": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-notifications": "~56.0.15",
    "expo-status-bar": "~56.0.4",
    "firebase": "^12.14.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "zip:mod": "cd tools && rm -f ../dist/ApexLap-mod.zip && zip -rq ../dist/ApexLap-mod.zip ApexLap -x '*/.DS_Store'",
    "deploy:web": "expo export --platform web && npm run zip:mod && firebase deploy --only hosting,firestore:rules",
    "build:apk": "eas build -p android --profile preview"
  },
  "private": true
}
