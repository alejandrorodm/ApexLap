# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
# APK de release (grande; se sube a hosting en el deploy, no a git)
release/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files (credenciales de prueba del mod, etc.) — NUNCA subir
.env
.env*.local

# SECRETOS: claves de cuenta de servicio, tokens, etc. NUNCA subir.
.secrets/
*serviceaccount*.json
*-adminsdk-*.json
google-services*.local.json

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Firebase CLI cache / junk
.firebase/
aaa.txt

# logs de Assetto Corsa / CSP que se peguen para depurar el mod
logs/

# Ficheros de configuración de agentes de IA
CLAUDE.md
AGENTS.md
.claude/
