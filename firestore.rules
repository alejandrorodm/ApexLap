rules_version = '2';

// Reglas de seguridad para Firestore.
// Pégalas en Firebase Console › Firestore Database › Rules (pestaña "Reglas")
// y pulsa "Publicar".
//
// Modelo: cualquiera que haya iniciado sesión (anónima incluida) puede leer y
// escribir en las ligas. Cada usuario solo puede crear/editar vueltas a su
// nombre y borrar las suyas. Suficiente para un grupo de colegas de confianza.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Perfiles: cada quien gestiona el suyo; todos pueden leerlos (para nombres).
    match /profiles/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == userId;
    }

    // Ligas: lectura/creación para cualquier usuario autenticado.
    match /leagues/{leagueId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn()
        && resource.data.createdBy == request.auth.uid;

      // Vueltas dentro de una liga.
      // Crea cada quien las suyas. Editar/borrar: el dueño O el anfitrión de la
      // liga (para que el anfitrión pueda verificar/rechazar/limpiar vueltas).
      match /laps/{lapId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if signedIn() && (
          resource.data.userId == request.auth.uid
          || get(/databases/$(database)/documents/leagues/$(leagueId)).data.createdBy == request.auth.uid
        );
      }

      // Piques (challenges) dentro de una liga.
      match /challenges/{challengeId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if signedIn()
          && resource.data.createdBy == request.auth.uid;

        // Apuestas: cada piloto gestiona la suya (id del doc = su uid);
        // todos las pueden leer. Solo se permite apostar en piques abiertos.
        match /bets/{userId} {
          allow read: if signedIn();
          allow write: if signedIn()
            && request.auth.uid == userId
            && get(/databases/$(database)/documents/leagues/$(leagueId)/challenges/$(challengeId)).data.status != 'closed';
        }
      }
    }
  }
}
